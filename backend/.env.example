// Backend environment variables
NODE_ENV=development
PORT=5000

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/heartbeat_db?sslmode=require"

# JWT Secret (change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ML API (optional - for Python model)
ML_API_URL=http://localhost:5001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001
# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001

# Alert Thresholds (default values)
DEFAULT_MIN_BPM=50
DEFAULT_MAX_BPM=120
DEFAULT_CRITICAL_MIN_BPM=40
DEFAULT_CRITICAL_MAX_BPM=140
